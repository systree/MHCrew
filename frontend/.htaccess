Options -MultiViews

# --- Cache control ---
# index.html must never be cached — it's the entry point the browser and SW
# use to discover the new hashed JS/CSS bundles. If it's cached, the user
# gets the old app indefinitely regardless of SW updates.
<FilesMatch "^index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# Hashed JS/CSS/media assets can be cached long-term — the filename changes
# on every build so there's no stale-content risk.
<FilesMatch "\.(js|css|woff2|png|svg|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Service worker must not be cached — browser needs to fetch it fresh to
# detect updates. sw-custom.js is the generated SW filename from VitePWA.
<FilesMatch "^(sw-custom\.js|workbox-.+\.js)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]
