PORT=3001
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
GHL_API_BASE_URL=https://services.leadconnectorhq.com
# Your GHL Marketplace App ID (visible in GHL → App Marketplace → Your App)
GHL_APP_ID=
# n8n endpoint that returns { access_token } given location_id + app_id query params
N8N_TOKEN_ENDPOINT=https://n8n.app.systree.com.au/webhook/get-token
# Ed25519 public key from GHL app settings (Marketplace → Your App → Webhook → Signature)
# Flatten the PEM onto one line — replace actual newlines with \n, wrap in double quotes:
GHL_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VwAyEAi2HR1srL4o18O8BRa7gVJY7G7bupbN3H9AwJrHCDiOg=\n-----END PUBLIC KEY-----"
JWT_SECRET=
MOBILEMESSAGE_API_KEY=
MOBILEMESSAGE_SENDER_ID=MoverHero
# Dev bypass: comma-separated phones that skip SMS and log OTP to console instead
# e.g. OTP_BYPASS_PHONES=+61412345678,+61498765432
OTP_BYPASS_PHONES=
# Web Push (VAPID) — generate keys once with:  npx web-push generate-vapid-keys
# Then copy the output below. VAPID_SUBJECT should be a mailto: or https: URL.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@moverhero.com.au
